  "description": "systemd journal の長期 archive 集計 (Garage gold/ parquet を MyDuck 経由で query)。silver 2025-10-18 以降の全期間カバー。shinbunbun/dotfiles-private#263",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "liveNow": false,
  "panels": [
    {
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 10,
      "title": "Volume (日次レベル別)",
      "type": "row"
    },
    {
      "datasource": {"type": "postgres", "uid": "PmyduckPoc0001"},
      "description": "gold/volume をレベル別に集計。 systemd は host (homemachine / nixos-desktop / mac mini 等) と service (systemd unit) が有意な分析次元、 現状は level のみ stack で全体傾向を見る。 host/service drill-down は将来 variable 化検討余地あり。",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "axisLabel": "rows/day",
            "axisPlacement": "auto",
            "drawStyle": "bars",
            "fillOpacity": 70,
            "gradientMode": "none",
            "hideFrom": {"tooltip": false, "viz": false, "legend": false},
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "stacking": {"group": "A", "mode": "normal"},
            "thresholdsStyle": {"mode": "off"}
          },
          "mappings": [],
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 9, "w": 24, "x": 0, "y": 1},
      "id": 1,
      "options": {
        "legend": {"calcs": ["sum"], "displayMode": "table", "placement": "right", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "datasource": {"type": "postgres", "uid": "PmyduckPoc0001"},
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT date AS time, level AS metric, sum(count)::BIGINT AS value FROM read_parquet('s3://logs-archive/gold/volume/source=systemd/date=*/data.parquet', hive_partitioning=true) WHERE $__timeFilter(date) GROUP BY date, level ORDER BY date, level",
          "refId": "A"
        }
      ],
      "title": "Volume by level (日次)",
      "type": "timeseries"
    },
    {
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 10},
      "id": 20,
      "title": "Template rate top-10",
      "type": "row"
    },
    {
      "datasource": {"type": "postgres", "uid": "PmyduckPoc0001"},
      "description": "範囲内で出現量 top-10 の template_id を抽出し、 日次 rate を描画。 anomaly detection は本 panel + 閾値が候補。 template_text は別 panel (templates dict 不在のため未実装、 shinbunbun/dotfiles-private#269 参照)。",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "axisLabel": "rows/day",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "pointSize": 4,
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "short"
        }
      },
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 11},
      "id": 2,
      "options": {
        "legend": {"calcs": ["sum"], "displayMode": "table", "placement": "right", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "datasource": {"type": "postgres", "uid": "PmyduckPoc0001"},
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "WITH top_ids AS (SELECT template_id FROM read_parquet('s3://logs-archive/gold/template_rate/source=systemd/date=*/data.parquet', hive_partitioning=true) WHERE $__timeFilter(date) GROUP BY template_id ORDER BY sum(count) DESC LIMIT 10) SELECT date AS time, ('tid=' || template_id)::TEXT AS metric, sum(count)::BIGINT AS value FROM read_parquet('s3://logs-archive/gold/template_rate/source=systemd/date=*/data.parquet', hive_partitioning=true) WHERE $__timeFilter(date) AND template_id IN (SELECT template_id FROM top_ids) GROUP BY date, template_id ORDER BY date, template_id",
          "refId": "A"
        }
      ],
      "title": "Top-10 template_id daily rate",
      "type": "timeseries"
    },
    {
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 21},
      "id": 30,
      "title": "Template first seen (new template anomaly)",
      "type": "row"
    },
    {
      "datasource": {"type": "postgres", "uid": "PmyduckPoc0001"},
      "description": "日次で新規出現した template の件数。 systemd は新 unit deploy / package update / kernel log の新パターンで増加。 急増は OS 構成変更や新サービス展開のサイン。",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "custom": {
            "axisLabel": "new templates/day",
            "drawStyle": "bars",
            "fillOpacity": 80,
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 100},
              {"color": "red", "value": 300}
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 22},
      "id": 3,
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom", "showLegend": false},
        "tooltip": {"mode": "single"}
      },
      "targets": [
        {
          "datasource": {"type": "postgres", "uid": "PmyduckPoc0001"},
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT date AS time, count(*)::BIGINT AS value FROM read_parquet('s3://logs-archive/gold/template_first_seen/source=systemd/date=*/data.parquet', hive_partitioning=true) WHERE $__timeFilter(date) GROUP BY date ORDER BY date",
          "refId": "A"
        }
      ],
      "title": "New template count (per day)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "postgres", "uid": "PmyduckPoc0001"},
      "description": "範囲内の新規 template 一覧 (新しい first_seen_ts 順)。 template_text は 'templates dict' 未実装のため非表示 (shinbunbun/dotfiles-private#269)。",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "custom": {"align": "left", "displayMode": "auto"}
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 22},
      "id": 4,
      "options": {
        "showHeader": true,
        "sortBy": [{"desc": true, "displayName": "first_seen_jst"}]
      },
      "targets": [
        {
          "datasource": {"type": "postgres", "uid": "PmyduckPoc0001"},
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT template_id, first_seen_ts AT TIME ZONE 'Asia/Tokyo' AS first_seen_jst, date AS first_seen_date FROM read_parquet('s3://logs-archive/gold/template_first_seen/source=systemd/date=*/data.parquet', hive_partitioning=true) WHERE $__timeFilter(date) ORDER BY first_seen_ts DESC LIMIT 50",
          "refId": "A"
        }
      ],
      "title": "新規 template 一覧 (range 内、新しい順)",
      "type": "table"
    },
    {
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 30},
