          "rawSql": "SELECT max(date) AS time, count(DISTINCT template_id)::BIGINT AS value FROM read_parquet('s3://logs-archive/gold/template_rate/source=systemd/date=*/data.parquet', hive_partitioning=true) WHERE $__timeFilter(date)",
