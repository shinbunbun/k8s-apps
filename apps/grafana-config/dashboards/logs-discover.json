{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "OpenSearch Discover 相当のログ検索 UI。host/service/level/job/フリーテキストでフィルタし、ヒストグラム + 生ログを同時表示。詳細探索は Logs Drilldown (grafana-lokiexplore-app) または Explore に遷移。",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "tags": ["logs", "loki", "discover", "search"],
  "timezone": "browser",
  "title": "Logs Discover",
  "uid": "logs-discover",
  "schemaVersion": 41,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "templating": {
    "list": [
      {
        "name": "job",
        "type": "query",
        "label": "Job",
        "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
        "definition": "label_values(job)",
        "query": { "label": "job", "refId": "LokiVariableQueryEditor-VariableQuery", "stream": "", "type": 1 },
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "allValue": ".+",
        "sort": 1,
        "current": { "text": "All", "value": "$__all", "selected": false }
      },
      {
        "name": "host",
        "type": "query",
        "label": "Host",
        "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
        "definition": "label_values({job=~\"$job\"}, host)",
        "query": { "label": "host", "refId": "LokiVariableQueryEditor-VariableQuery", "stream": "{job=~\"$job\"}", "type": 1 },
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "allValue": ".+",
        "sort": 1,
        "current": { "text": "All", "value": "$__all", "selected": false }
      },
      {
        "name": "service",
        "type": "query",
        "label": "Service",
        "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
        "definition": "label_values({job=~\"$job\", host=~\"$host\"}, service)",
        "query": { "label": "service", "refId": "LokiVariableQueryEditor-VariableQuery", "stream": "{job=~\"$job\", host=~\"$host\"}", "type": 1 },
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "allValue": ".+",
        "sort": 1,
        "current": { "text": "All", "value": "$__all", "selected": false }
      },
      {
        "name": "level",
        "type": "custom",
        "label": "Level",
        "query": "emergency,alert,critical,error,warning,notice,info,debug",
        "multi": true,
        "includeAll": true,
        "allValue": ".+",
        "current": { "text": "All", "value": "$__all", "selected": false },
        "options": [
          { "text": "All", "value": "$__all", "selected": true },
          { "text": "emergency", "value": "emergency", "selected": false },
          { "text": "alert", "value": "alert", "selected": false },
          { "text": "critical", "value": "critical", "selected": false },
          { "text": "error", "value": "error", "selected": false },
          { "text": "warning", "value": "warning", "selected": false },
          { "text": "notice", "value": "notice", "selected": false },
          { "text": "info", "value": "info", "selected": false },
          { "text": "debug", "value": "debug", "selected": false }
        ]
      },
      {
        "name": "search",
        "type": "textbox",
        "label": "Search (regex)",
        "query": "",
        "current": { "text": "", "value": "" },
        "description": "LogQL の |~ に渡されるキーワード。空なら絞り込みなし。正規表現 OK。"
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "id": 100,
      "title": "概要",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "id": 1,
      "title": "ログヒストグラム (level 別)",
      "description": "選択した host/service/level/job/search の範囲で、時系列のログ件数を level ごとに色分け表示。",
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "gridPos": { "h": 8, "w": 18, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "custom": {
            "drawStyle": "bars",
            "lineInterpolation": "linear",
            "fillOpacity": 80,
            "stacking": { "mode": "normal", "group": "A" }
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".*error.*|.*critical.*|.*emergency.*|.*alert.*" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }]
          },
          {
            "matcher": { "id": "byRegexp", "options": ".*warning.*" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["sum"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
          "expr": "sum by (level) (count_over_time({job=~\"$job\", host=~\"$host\", service=~\"$service\", level=~\"$level\"} |~ \"$search\" [$__interval]))",
          "legendFormat": "{{ level }}"
        }
      ]
    },
    {
      "type": "stat",
      "id": 2,
      "title": "Top hosts (1h、件数)",
      "description": "過去 1 時間の絞り込み範囲内で、ホスト別ログ件数の上位 5。",
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
          "expr": "topk(5, sum by (host) (count_over_time({job=~\"$job\", host=~\"$host\", service=~\"$service\", level=~\"$level\"} |~ \"$search\" [1h])))",
          "legendFormat": "{{ host }}"
        }
      ]
    },
    {
      "type": "stat",
      "id": 3,
      "title": "Top services (1h、件数)",
      "description": "過去 1 時間の絞り込み範囲内で、サービス別ログ件数の上位 5。",
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 5 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
          "expr": "topk(5, sum by (service) (count_over_time({job=~\"$job\", host=~\"$host\", service=~\"$service\", level=~\"$level\"} |~ \"$search\" [1h])))",
          "legendFormat": "{{ service }}"
        }
      ]
    },
    {
      "type": "row",
      "id": 101,
      "title": "ログ",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "logs",
      "id": 4,
      "title": "生ログ",
      "description": "ログ行をクリックで詳細表示。前後のコンテキストは Log Context ボタンから。",
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "gridPos": { "h": 20, "w": 24, "x": 0, "y": 10 },
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "signature",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
          "expr": "{job=~\"$job\", host=~\"$host\", service=~\"$service\", level=~\"$level\"} |~ \"$search\"",
          "maxLines": 1000
        }
      ]
    }
  ]
}
