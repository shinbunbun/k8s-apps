      "targets": [
        {
          "rawSql": "WITH t AS (\n  SELECT toDateTime64(timestamp, 6) AS ts, host, date\n  FROM s3(garage, filename='daily-struct/source=routeros/date=*/logs.parquet')\n)\nSELECT\n  coalesce(host, '(unknown)') AS host,\n  count() AS cnt\nFROM t\nWHERE toDate(date) >= toDate($__fromTime)\n  AND toDate(date) <= toDate($__toTime)\n  AND $__timeFilter(ts)\nGROUP BY 1\nORDER BY cnt DESC\nLIMIT 10",
          "format": 1,
          "refId": "A"
