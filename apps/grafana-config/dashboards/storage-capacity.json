{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Garage クラスタのノード別 disk 使用量、Loki ingestion、Parquet アーカイブ (Phase 2 以降) を統合監視。per-bucket 使用量は Garage の /metrics に無いため表示しない (garage bucket list を別途参照)。",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "tags": ["storage", "garage", "loki", "capacity"],
  "timezone": "browser",
  "title": "Storage Capacity",
  "uid": "storage-capacity",
  "schemaVersion": 41,
  "version": 1,
  "refresh": "1m",
  "time": {
    "from": "now-7d",
    "to": "now"
  },
  "timepicker": {},
  "templating": {
    "list": []
  },
  "panels": [
    {
      "type": "row",
      "id": 100,
      "title": "Garage 全体",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "gauge",
      "id": 1,
      "title": "Garage Disk 使用率 (最大ノード)",
      "description": "最も使用率の高いノードの disk 使用率。70% で warning、85% で critical のアラートが発火する (GarageDiskUsageHigh/Critical)。RF=3 で raw 120GiB → usable ~40GiB。",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 1 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "minVizWidth": 75,
        "minVizHeight": 75
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.85 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "max(1 - garage_local_disk_avail / garage_local_disk_total)",
          "legendFormat": "使用率"
        }
      ]
    },
    {
      "type": "stat",
      "id": 2,
      "title": "使用量 / 実効容量 (推定)",
      "description": "Garage ノード全体の used bytes 合計と、RF=3 前提の usable 容量 (total / 3)。正確なバケット使用量は garage bucket list コマンドで確認。",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 1 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "decbytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "sum(garage_local_disk_total - garage_local_disk_avail)",
          "legendFormat": "使用量 (raw)"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "sum(garage_local_disk_total) / 3",
          "legendFormat": "実効容量 (raw/RF)"
        }
      ]
    },
    {
      "type": "stat",
      "id": 3,
      "title": "30 日後予測空き容量 (最小ノード)",
      "description": "過去 7 日の空き容量トレンドを線形外挿。total の 10% 未満になると GarageDiskExhaustionPredicted アラートが発火。",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 1 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "decbytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 4294967296 },
              { "color": "green", "value": 8589934592 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "min(predict_linear(garage_local_disk_avail[7d], 86400 * 30))",
          "legendFormat": "30 日後予測空き (最小)"
        }
      ]
    },
    {
      "type": "row",
      "id": 101,
      "title": "Garage ノード別使用量推移",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 8 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "id": 4,
      "title": "Garage ノード別 disk 使用量",
      "description": "各 Garage ノードの disk used (raw)。ノード単位の偏りと日次の増加傾向を確認。",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "fieldConfig": {
        "defaults": {
          "unit": "decbytes",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "spanNulls": true
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "実効容量" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }
            ]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "garage_local_disk_total - garage_local_disk_avail",
          "legendFormat": "{{ instance }}"
        }
      ]
    },
    {
      "type": "timeseries",
      "id": 5,
      "title": "Garage ノード別 disk 空き容量",
      "description": "各ノードの残り空き容量 (garage_local_disk_avail)。GarageDiskExhaustionPredicted アラートは 30 日後予測 < 総容量の 10% で発報。per-bucket 使用量は Garage の /metrics に無いため表示不可、`garage bucket list` で確認する。",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "fieldConfig": {
        "defaults": {
          "unit": "decbytes",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "min"] },
        "tooltip": { "mode": "multi", "sort": "asc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "garage_local_disk_avail",
          "legendFormat": "{{ instance }}"
        }
      ]
    },
    {
      "type": "row",
      "id": 102,
      "title": "Loki Ingestion",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "id": 6,
      "title": "Loki Ingestion Rate",
      "description": "Loki distributor が受信しているバイト数レート。LokiIngestionRateSpike アラート連動。",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "mean"] },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "sum(rate(loki_distributor_bytes_received_total[5m]))",
          "legendFormat": "ingestion"
        }
      ]
    },
    {
      "type": "timeseries",
      "id": 7,
      "title": "Loki Chunks Flushed",
      "description": "Garage に書き出された chunks の累積数と速度。loki-chunks バケット成長の原動力。",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "mean"] },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "sum(rate(loki_ingester_chunks_flushed_total[5m]))",
          "legendFormat": "flushed/s"
        }
      ]
    }
  ]
}
