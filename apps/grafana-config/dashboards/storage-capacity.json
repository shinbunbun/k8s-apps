{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "MinIO 容量、バケット別使用量、Loki ingestion、Parquet アーカイブ (Phase 2 以降) を統合監視。Phase 0: ストレージ監視基盤。",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "tags": ["storage", "minio", "loki", "capacity"],
  "timezone": "browser",
  "title": "Storage Capacity",
  "uid": "storage-capacity",
  "schemaVersion": 41,
  "version": 1,
  "refresh": "1m",
  "time": {
    "from": "now-7d",
    "to": "now"
  },
  "timepicker": {},
  "templating": {
    "list": []
  },
  "panels": [
    {
      "type": "row",
      "id": 100,
      "title": "MinIO 全体",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "gauge",
      "id": 1,
      "title": "MinIO 使用率",
      "description": "実効容量 (EC:3 適用後、60 GiB 相当) に対する使用率。70% で warning、85% で critical のアラートが発火する。",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 1 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "minVizWidth": 75,
        "minVizHeight": 75
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.85 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "minio_cluster_usage_total_bytes / minio_cluster_capacity_usable_total_bytes",
          "legendFormat": "使用率"
        }
      ]
    },
    {
      "type": "stat",
      "id": 2,
      "title": "使用量 / 実効容量",
      "description": "MinIO の実使用バイト数と EC:3 後の実効容量。",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 1 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "decbytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "minio_cluster_usage_total_bytes",
          "legendFormat": "使用量"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "minio_cluster_capacity_usable_total_bytes",
          "legendFormat": "実効容量"
        }
      ]
    },
    {
      "type": "stat",
      "id": 3,
      "title": "30 日後予測使用量",
      "description": "過去 7 日の増加率を線形外挿。実効容量を超えると MinIOClusterExhaustionPredicted アラートが発火。",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 1 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "decbytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 42949672960 },
              { "color": "red", "value": 55834574848 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "predict_linear(minio_cluster_usage_total_bytes[7d], 86400 * 30)",
          "legendFormat": "30 日後予測"
        }
      ]
    },
    {
      "type": "row",
      "id": 101,
      "title": "MinIO 使用量推移",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 8 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "id": 4,
      "title": "MinIO 全体使用量推移",
      "description": "クラスタ全体の使用量 vs 実効容量。日次の増加傾向を確認。",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "fieldConfig": {
        "defaults": {
          "unit": "decbytes",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "spanNulls": true
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "実効容量" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }
            ]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "minio_cluster_usage_total_bytes",
          "legendFormat": "使用量"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "minio_cluster_capacity_usable_total_bytes",
          "legendFormat": "実効容量"
        }
      ]
    },
    {
      "type": "timeseries",
      "id": 5,
      "title": "バケット別使用量",
      "description": "loki-chunks / cnpg-backups / logs-archive (Phase 2 以降) など各バケットの使用量推移。",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "fieldConfig": {
        "defaults": {
          "unit": "decbytes",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "stacking": { "mode": "normal" }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "minio_bucket_usage_total_bytes",
          "legendFormat": "{{ bucket }}"
        }
      ]
    },
    {
      "type": "row",
      "id": 102,
      "title": "Loki Ingestion",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "id": 6,
      "title": "Loki Ingestion Rate",
      "description": "Loki distributor が受信しているバイト数レート。LokiIngestionRateSpike アラート連動。",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "mean"] },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "sum(rate(loki_distributor_bytes_received_total[5m]))",
          "legendFormat": "ingestion"
        }
      ]
    },
    {
      "type": "timeseries",
      "id": 7,
      "title": "Loki Chunks Flushed",
      "description": "MinIO に書き出された chunks の累積数と速度。loki-chunks バケット成長の原動力。",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "mean"] },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "sum(rate(loki_ingester_chunks_flushed_total[5m]))",
          "legendFormat": "flushed/s"
        }
      ]
    }
  ]
}
