    {
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "description": "Loki Ruler の log_errors_total (host/service/level 別) を VM に remote_write したもの。1 年レンジを右上の Time range で選択可能。",
      "fieldConfig": {
        "defaults": {
          "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 15, "stacking": {"mode": "normal"}},
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 28},
      "id": 41,
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["sum", "lastNotNull"]},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
          "expr": "sum by (host) (increase(log_errors_total[$__interval]))",
          "legendFormat": "{{ host }}"
        }
      ],
      "title": "エラー件数 (host 別、$__interval)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "description": "level (error/critical/alert/emergency) 別のエラー推移。",
      "fieldConfig": {
        "defaults": {
          "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 15, "stacking": {"mode": "normal"}},
          "unit": "short",
          "color": {"mode": "palette-classic"}
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "emergency"},
            "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "dark-red"}}]
          },
          {
            "matcher": {"id": "byName", "options": "critical"},
            "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "red"}}]
          },
          {
            "matcher": {"id": "byName", "options": "error"},
            "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "orange"}}]
          }
