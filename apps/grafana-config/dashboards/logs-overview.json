        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["sum", "lastNotNull"]},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
          "expr": "sum by (level) (increase(log_errors_total[$__interval]))",
          "legendFormat": "{{ level }}"
        }
      ],
      "title": "エラー件数 (level 別、$__interval)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "description": "過去 30 日の累積イベント数。0 件が正常。発生した場合は host 単位で確認。",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
