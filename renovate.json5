{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",

  extends: [
    "config:recommended",
    ":semanticCommits",
    ":timezone(Asia/Tokyo)",
    ":dependencyDashboard",
  ],

  commitMessageTopic: "{{depName}}",
  commitMessageAction: "更新",
  commitMessageExtra: "{{currentVersion}} → {{newVersion}}",
  labels: ["dependencies", "renovate"],

  schedule: ["before 9am on friday"],
  timezone: "Asia/Tokyo",

  dependencyDashboard: true,
  dependencyDashboardTitle: "📦 Renovate Dependency Dashboard",

  ignorePaths: [
    "**/*.enc.yaml",
    "apps/_templates/**",
  ],

  argocd: {
    managerFilePatterns: [
      "/^infrastructure/.+/application\\.yaml$/",
      "/^bootstrap/.+\\.yaml$/",
    ],
  },
  kubernetes: {
    managerFilePatterns: [
      "/^apps/.+/.+\\.yaml$/",
      "/^infrastructure/.+/.+\\.yaml$/",
      "/^jobs/.+\\.yaml$/",
      "/^manifests/.+\\.yaml$/",
    ],
  },

  packageRules: [
    {
      description: "Patch release は自動マージ",
      matchUpdateTypes: ["patch"],
      automerge: true,
      automergeType: "pr",
      platformAutomerge: true,
    },
    {
      description: "VictoriaMetrics スタックをグループ化",
      matchPackageNames: [
        "victoria-metrics-operator",
        "/^victoriametrics\\//",
      ],
      groupName: "victoriametrics",
    },
    {
      description: "Loki / Vector 関連をグループ化",
      matchPackageNames: ["loki", "vector", "log-archiver-vector"],
      groupName: "loki-stack",
    },
    {
      description: "CNPG 関連をグループ化",
      matchPackageNames: ["cloudnative-pg", "/^cnpg-/"],
      groupName: "cnpg",
    },
    {
      description: "Major は手動レビュー",
      matchUpdateTypes: ["major"],
      automerge: false,
      labels: ["dependencies", "renovate", "major"],
    },
    {
      description: "latest 系タグは追跡不可のため無効化",
      matchCurrentVersion: "/^(latest|stable|main|master|edge)$/",
      enabled: false,
    },
    {
      // scanopy server image は pg_dump 17 client を内蔵しており (scanopy/scanopy@9681c1e
      // "put PostgreSQL 17 client ahead of v16 on PATH")、upstream docker-compose.yml も
      // postgres:17-alpine を pin している。upstream が bump するまで major は追従しない。
      description: "scanopy の postgres major bump は upstream 追従待ち",
      matchFileNames: ["apps/scanopy/postgres-deployment.yaml"],
      matchPackageNames: ["postgres"],
      matchUpdateTypes: ["major"],
      enabled: false,
    },
    {
      // 起動時 pip install の duckdb wheel と python image の cpython ABI 整合が必要。
      // 2026-04 に renovate が python:3.12-slim → 3.14-slim を minor bump で merge し、
      // duckdb 1.1.3 が cp314 wheel 未提供で source build にフォールバック → slim image
      // に g++ 不在で日次 CronJob が完全停止した経緯あり (PR #196 で復旧)。
      // 今後は python image bump 時に duckdb 側の wheel 配布状況を必ず確認したいので、
      // major / minor の自動 PR は出さない (patch のみ追従で OK)。
      description: "logs-compact-cronjob の python image は major/minor を自動 bump させない (duckdb wheel 整合性確認が必要)",
      matchFileNames: ["apps/logs-compact-cronjob/cronjob.yaml"],
      matchPackageNames: ["python"],
      matchUpdateTypes: ["major", "minor"],
      enabled: false,
    },
  ],
}
